{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "tabWidth": 2,
  "semi": true,
  "trailingComma": "all",
  "bracketSpacing": true,
  "printWidth": 144,
  "sortPackageJson": false,
  "ignorePatterns": [
    "dist/",
    "public/",
    "docs/",
    "types/",
    "logs",
    "*.log",
    "npm-debug.log*",
    "yarn-debug.log*",
    "yarn-error.log*",
    "lerna-debug.log*",
    "report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json",
    "pids",
    "*.pid",
    "*.seed",
    "*.pid.lock",
    "lib-cov",
    "coverage",
    "*.lcov",
    ".nyc_output",
    ".grunt",
    "bower_components",
    ".lock-wscript",
    "build/Release",
    "node_modules/",
    "jspm_packages/",
    "typings/",
    "*.tsbuildinfo",
    ".npm",
    ".eslintcache",
    ".node_repl_history",
    "*.tgz",
    ".yarn-integrity",
    ".env",
    ".env.test",
    ".cache",
    ".next",
    ".nuxt",
    "dist/",
    ".vuepress/dist",
    ".serverless/",
    ".fusebox/",
    ".dynamodb/"
  ]
}
