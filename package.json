{
  "name": "@himenon/openapi-typescript-code-generator-play",
  "version": "0.1.0",
  "private": true,
  "homepage": "https://github.com/Himenon/tiny-react-app-template#readme",
  "bugs": "https://github.com/Himenon/tiny-react-app-template/issues",
  "repository": {
    "type": "git",
    "url": "git@github.com:Himenon/tiny-react-app-template.git"
  },
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "clean": "rimraf dist lib",
    "commit": "npx git-cz",
    "copy": "ts-node -P tsconfig.cli.json ./gen-docs.ts",
    "depcruise": "depcruise --validate .dependency-cruiser.cjs src",
    "depcruise:html": "depcruise --validate --output-type err-html -f dependency-report.html .dependency-cruiser.cjs src",
    "deploy": "pnpm build && pnpm publish:site",
    "dev": "vite",
    "format": "oxfmt --write .",
    "lint": "oxlint src",
    "lint:fix": "oxlint --fix src",
    "oxfmt": "oxfmt --write src",
    "preview": "vite preview",
    "publish:site": "ts-node -P ./scripts/tsconfig.cli.json ./scripts/publish.ts",
    "serve": "serve dist",
    "start": "vite",
    "test": "echo 'SKIP'",
    "test:jest": "jest -c ./jest.config.cjs",
    "test:jest:watch": "pnpm test:jest --watch",
    "version_up": "lerna version --yes"
  },
  "dependencies": {
    "@himenon/openapi-typescript-code-generator": "2.0.3",
    "@monaco-editor/react": "^4.7.0",
    "js-yaml": "^4.1.1",
    "lz-string": "1.5.0",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "styled-components": "6.4.1",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.2",
    "@commitlint/config-conventional": "20.5.0",
    "@swc/core": "^1.15.32",
    "@swc/helpers": "^0.5.21",
    "@swc/jest": "^0.2.39",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "30.0.0",
    "@types/js-yaml": "4.0.9",
    "@types/lz-string": "1.5.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/react-router-dom": "5.3.3",
    "@types/styled-components": "^5.1.36",
    "@vitejs/plugin-react": "^6.0.1",
    "cross-env": "10.1.0",
    "dependency-cruiser": "17.3.10",
    "fs-extra": "^11.3.4",
    "jest": "30.3.0",
    "lefthook": "^2.1.6",
    "lerna": "9.0.7",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "process": "^0.11.10",
    "serve": "14.2.6",
    "sort-package-json": "3.6.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "29.4.9",
    "ts-node": "10.9.2",
    "vite": "^8.0.10"
  },
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0"
  }
}
